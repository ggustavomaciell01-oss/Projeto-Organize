generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Task {
  id          BigInt   @id @default(autoincrement())
  title       String
  description String?

  dueDate     DateTime?   

  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categories  TaskCategoryRelation[]

  @@map("tasks")
}

model Finance {
  id          BigInt   @id @default(autoincrement())
  type        String
  amount      Decimal  @db.Decimal(10, 2)
  description String?

  date        DateTime   

  createdAt   DateTime @default(now())

  @@map("finances")
}

model Appointment {
  id          BigInt   @id @default(autoincrement())
  title       String
  description String?

  startTime   DateTime
  endTime     DateTime

  createdAt   DateTime @default(now())

  @@map("appointments")
}

model TaskCategory {
  id     BigInt   @id @default(autoincrement())
  name   String   @unique

  tasks  TaskCategoryRelation[]

  @@map("task_categories")
}

model TaskCategoryRelation {
  task       Task         @relation(fields: [taskId], references: [id])
  taskId     BigInt

  category   TaskCategory @relation(fields: [categoryId], references: [id])
  categoryId BigInt

  @@id([taskId, categoryId])

  @@map("task_category_relations")
}